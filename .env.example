# Get these from https://my.telegram.org -> API development tools
API_ID=1234567
API_HASH=your_api_hash_here

# Phone number in international format (used only for first-time login)
PHONE=+1234567890

# Path where the encrypted session is stored. Keep this file SECRET — it grants
# full access to your account. Default works for local + most VPS setups.
SESSION_NAME=userbot

# Comma-separated list of source channels/groups to copy from.
# Use @username, t.me/username, or numeric chat id (e.g. -1001234567890).
SOURCE_CHATS=@source_channel_1,@source_channel_2

# Destination channel (your own). You must be admin with post permission.
DEST_CHAT=@my_channel

# "copy" = repost without "Forwarded from" header (looks native)
# "forward" = native forward with attribution
MODE=copy

# Optional: only repost messages whose text contains ANY of these
# (comma-separated, case-insensitive). Leave blank to copy everything.
KEYWORDS=

# Optional: drop messages whose text contains ANY of these (comma-separated).
BLOCK_KEYWORDS=

# Optional: prepend/append text to copied messages (ignored in forward mode).
PREFIX=
SUFFIX=
